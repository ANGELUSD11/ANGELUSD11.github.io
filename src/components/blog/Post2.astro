                                #lo que queremos hacer:
                                #sumar      ([3, 4, 5]) + ([[1, 2],   ##ESTO NO SE PUEDE DEBIDO A QUE NO PODEMOS ASIGNAR CORRECTAMENTE LOS 3 VALORES NECESARIOS PARA CADA OPERACIÓN
                                #                           [3, 4],
