                                print(f"\n(A*B)+(A*C):\n{E}")

                                #comprobamos la igualdad entre las 2 matrices resultantes
                                print(f"\nIgualdad entre D y E: {np.array_equal(D, E)}")

                                # La propiedad conmutativa establece que:
