---
import Layout from "../layouts/Layout.astro";
---

<Layout title="ANGELUS11 - Developer">
    <div id="particles-js"></div>

    <!-- Language Switcher Button -->
    <div class="language-switcher">
        <button id="langBtn" class="btn btn-outline-primary">
            <i class="fas fa-globe"></i>
            <span id="langText">EN</span>
        </button>
    </div>

    <div class="container">
        <!-- Hero Section -->
        <section class="hero-section text-center py-5">
            <div class="logo-container">
                <img src="/logo.webp" alt="ANGELUS11 Logo" class="logo-image" />
            </div>
            <h1
                class="display-1 fw-bold gradient-text mt-4"
                data-es="ANGELUS11"
                data-en="ANGELUS11"
            >
                ANGELUS11
            </h1>
            <p
                class="lead text-primary"
                data-es="Desarrollador de software/gamedev"
                data-en="Software Developer/gamedev"
            >
                Desarrollador de software/gamedev
            </p>
        </section>

        <!-- Social Links -->
        <section class="social-section py-4">
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a
                    href="https://discord.com/invite/ne3U8RS8bA"
                    target="_blank"
                    class="social-link"
                >
                    <i class="fab fa-discord"></i>
                    <span>Discord</span>
                </a>
                <a
                    href="https://github.com/ANGELUSD11"
                    target="_blank"
                    class="social-link"
                >
                    <i class="fab fa-github"></i>
                    <span>GitHub</span>
                </a>
                <a
                    href="https://www.youtube.com/@ANGELUSD11"
                    target="_blank"
                    class="social-link"
                >
                    <i class="fab fa-youtube"></i>
                    <span>YouTube</span>
                </a>
                <a
                    href="https://twitter.com/ANGELUSD11"
                    target="_blank"
                    class="social-link"
                >
                    <i class="fab fa-twitter"></i>
                    <span>Twitter</span>
                </a>
                <a
                    href="https://www.twitch.tv/angelusd11"
                    target="_blank"
                    class="social-link"
                >
                    <i class="fab fa-twitch"></i>
                    <span>Twitch</span>
                </a>
                <a
                    href="https://www.linkedin.com/in/angelleonardohern11"
                    target="_blank"
                    class="social-link"
                >
                    <i class="fab fa-linkedin"></i>
                    <span>LinkedIn</span>
                </a>
                <a href="/blog" class="social-link">
                    <i class="fas fa-blog"></i>
                    <span>Blog</span>
                </a>
            </div>

            <!-- Subscriber Counter -->
            <div class="d-flex justify-content-center mt-4">
                <div
                    class="card bg-dark-subtle border-primary"
                    style="max-width: 400px; width: 100%;"
                >
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3">
                            <div class="p-3 rounded bg-primary bg-opacity-10">
                                <i
                                    class="fas fa-users text-primary"
                                    style="font-size: 2rem;"></i>
                            </div>
                            <div>
                                <p
                                    class="text-secondary mb-1"
                                    data-es="Suscriptores en YouTube"
                                    data-en="YouTube Subscribers"
                                    style="color: white !important;"
                                >
                                    Suscriptores en YouTube
                                </p>
                                <p
                                    class="text-primary fw-bold mb-0"
                                    style="font-size: 2rem; color: white !important;"
                                    id="subscriberCount"
                                >
                                    ...
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- About Section -->
        <section class="about-section py-5">
            <div class="card bg-dark-subtle border-primary">
                <div class="card-body">
                    <h2 class="card-title text-primary mb-4">
                        <i class="fas fa-user me-2"></i>
                        <span data-es="Sobre mí" data-en="About Me"
                            >Sobre mí</span
                        >
                    </h2>
                    <p
                        class="card-text"
                        data-es="Mi nombre es Angel💠, actualmente tengo 20 años. Desde los 16 años aprendí a programar de manera autodidacta, me apasiona la tecnología y la innovación. Actualmente me encuentro trabajando como desarrollador e investigador de software en varios proyectos empresariales, mientras estudio la carrera de ingeniería de software. Mi mayor skill es con el ecosistema de Python🐍, junto con varias librerías de CV, backend y videojuegos. Además de gamedev con Godot, tengo un canal de Youtube donde suelo hablar de programación, modding y desarrollo de videojuegos."
                        data-en="My name is Angel💠, I am currently 20 years old. Since I was 16, I have been self-taught in programming, passionate about technology and innovation. I am currently working as a software developer and researcher on several business projects while studying for a degree in software engineering. My greatest skill is with the Python ecosystem🐍, along with various CV, backend, and game development libraries. In addition to gamedev with Godot, I have a YouTube channel where I often talk about programming, modding, and game development."
                        style="color: white !important;"
                    >
                        Mi nombre es Angel💠, actualmente tengo 20 años. Desde
                        los 16 años aprendí a programar de manera autodidacta,
                        me apasiona la tecnología y la innovación. Actualmente
                        me encuentro trabajando como desarrollador e
                        investigador de software en varios proyectos
                        empresariales, mientras estudio la carrera de ingeniería
                        de software. Mi mayor skill es con el ecosistema de
                        Python🐍, junto con varias librerías de CV, backend y
                        videojuegos. Además de gamedev con Godot, tengo un canal
                        de Youtube donde suelo hablar de programación, modding y
                        desarrollo de videojuegos.
                    </p>
                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section class="projects-section py-5">
            <h2 class="text-center text-primary mb-5">
                <i class="fas fa-code me-2"></i>
                <span data-es="Mis Proyectos" data-en="My Projects"
                    >Mis Proyectos</span
                >
            </h2>
            <div class="row g-4 justify-content-center">
                <div class="col-md-4">
                    <div
                        class="card project-card h-100 bg-dark-subtle border-primary"
                    >
                        <img
                            src="/images/discordbot.webp"
                            class="card_img-top"
                            style="border: 1px solid aqua; border-radius: 30px; corner-shape: bevel;"
                            alt=""
                        />
                        <div class="card-body">
                            <h3 class="card-title text-primary">TDMBOT💠</h3>
                            <p
                                class="card-text text-secondary"
                                data-es="Un bot de Discord multifuncional con comandos de moderación, música y entretenimiento."
                                data-en="A multifunctional Discord bot with moderation, music, and entertainment commands."
                                style="color: white !important;"
                            >
                                Un bot de Discord multifuncional con comandos de
                                moderación, música y entretenimiento.
                            </p>
                            <a
                                href="https://discord.com/oauth2/authorize?client_id=1367861699683549276"
                                target="_blank"
                                class="btn btn-outline-primary"
                            >
                                <span
                                    data-es="Ver proyecto"
                                    data-en="View project">Ver proyecto</span
                                > →
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div
                        class="card project-card h-100 bg-dark-subtle border-success"
                    >
                        <img
                            src="/images/bertochat.webp"
                            class="card_img-top"
                            style="border: 1px solid aqua; border-radius: 30px; corner-shape: bevel"
                            alt=""
                        />
                        <div class="card-body">
                            <h3 class="card-title text-success">Berto AI🌱</h3>
                            <p
                                class="card-text text-secondary"
                                data-es="Asistente de inteligencia artificial para agricultura con capacidades de conversación natural, puede leer imágenes."
                                data-en="Artificial intelligence assistant for agriculture with natural conversation capabilities, able to read images."
                                style="color: white !important;"
                            >
                                Asistente de inteligencia artificial para
                                agricultura con capacidades de conversación
                                natural, puede leer imágenes.
                            </p>
                            <a
                                href="https://berto-ai.onrender.com/"
                                target="_blank"
                                class="btn btn-outline-success"
                            >
                                <span
                                    data-es="Ver proyecto"
                                    data-en="View project">Ver proyecto</span
                                > →
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div
                        class="card project-card h-100 bg-dark-subtle border-info"
                    >
                        <img
                            src="/images/lvlid.webp"
                            class="card_img-top"
                            style="border: 1px solid aqua; border-radius: 30px; corner-shape: bevel"
                            alt=""
                        />
                        <div class="card-body">
                            <h3 class="card-title text-info">RobTopLvlID🔎</h3>
                            <p
                                class="card-text text-secondary"
                                data-es="Herramienta basada en una red neuronal convolucional para buscar y analizar niveles de Geometry Dash."
                                data-en="CNN Tool to search and analyze Geometry Dash levels."
                                style="color: white !important;"
                            >
                                Herramienta basada en una red neuronal
                                convolucional para buscar y analizar niveles de
                                Geometry Dash.
                            </p>
                            <a
                                href="https://huggingface.co/spaces/ANGELUSD11/RobtopLvlIdentifier1"
                                target="_blank"
                                class="btn btn-outline-info"
                            >
                                <span
                                    data-es="Ver proyecto"
                                    data-en="View project">Ver proyecto</span
                                > →
                            </a>

                            <a
                                href="https://huggingface.co/ANGELUSD11/RobtopLvlID/tree/main"
                                target="_blank"
                                class="btn btn-outline-info"
                            >
                                <span data-es="Ver modelo" data-en="View model"
                                    >Ver modelo</span
                                > →
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div
                        class="card project-card h-100 bg-dark-subtle border-primary"
                    >
                        <img
                            src="/images/conceptoadvad.png"
                            class="card_img-top"
                            style="border: 1px solid aqua; border-radius: 30px; corner-shape: bevel;"
                            alt="ADVAD Game"
                        />
                        <div class="card-body">
                            <h3 class="card-title text-primary">ADVAD</h3>
                            <p
                                class="card-text text-secondary"
                                data-es="Juego de naves espaciales estilo 'shoot 'em up'. ¡Esquiva y dispara para sobrevivir!"
                                data-en="A 'shoot 'em up' style spaceship game. Dodge and shoot to survive!"
                                style="color: white !important;"
                            >
                                Juego de naves espaciales estilo 'shoot 'em up'.
                                ¡Esquiva y dispara para sobrevivir!
                            </p>
                            <a href="/advad" class="btn btn-outline-primary">
                                <span data-es="Jugar ahora" data-en="Play now"
                                    >Jugar ahora</span
                                > →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Game Section -->
        <section class="game-section py-5">
            <h2 class="text-center text-primary mb-5">
                🚀 <span data-es="ADVAD (DEMO)" data-en="ADVAD (DEMO)"
                    >ADVAD (DEMO)</span
                >
            </h2>
            <div class="d-flex justify-content-center">
                <iframe
                    frameborder="0"
                    src="https://itch.io/embed/3972224?bg_color=234446&fg_color=58fffa&link_color=7bfffd&border_color=276ea5"
                    width="552"
                    height="167"
                >
                    <a href="https://angelus11.itch.io/advad-demo">ADVAD (DEMO)
                    by ANGELUSD11</a>
                </iframe>
            </div>
        </section>

        <!-- Skills Section -->
        <section class="skills-section py-5">
            <h2 class="text-center text-primary mb-5">
                <i class="fas fa-database me-2"></i>
                <span data-es="Mis Skills" data-en="My Skills">Mis Skills</span>
            </h2>
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <div class="skill-icon">
                    <img
                        src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg"
                        alt="HTML5"
                    />
                </div>
                <div class="skill-icon">
                    <img
                        src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg"
                        alt="CSS3"
                    />
                </div>
                <div class="skill-icon">
                    <img
                        src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bootstrap/bootstrap-original.svg"
                        alt="Bootstrap"
                    />
                </div>
                <div class="skill-icon">
                    <img
                        src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg"
                        alt="Python"
                    />
                </div>
                <div class="skill-icon">
                    <img
                        src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg"
                        alt="Git"
                    />
                </div>
                <div class="skill-icon">
                    <img
                        src="https://skillicons.dev/icons?i=godot"
                        alt="Godot"
                    />
                </div>
            </div>
        </section>

        <!-- YouTube Section -->
        <section class="youtube-section py-5">
            <h2 class="text-center text-primary mb-4">
                <i class="fab fa-youtube me-2"></i>
                <span data-es="Último Video" data-en="Latest Video"
                    >Último Video</span
                >
            </h2>
            <div class="ratio ratio-16x9">
                <iframe
                    src="https://www.youtube.com/embed/sAzCZgJi-3M?si=T7n6DEckk8E4oSph"
                    title="YouTube video"
                    allowfullscreen></iframe>
            </div>
        </section>
    </div>

    <!-- Particles.js -->
    <script
        is:inline
        src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"
    ></script>
    <script is:inline>
        particlesJS("particles-js", {
            particles: {
                number: {
                    value: 50,
                    density: {
                        enable: true,
                        value_area: 800,
                    },
                },
                color: {
                    value: "#06b6d4",
                },
                shape: {
                    type: "circle",
                },
                opacity: {
                    value: 0.3,
                    random: true,
                },
                size: {
                    value: 3,
                    random: true,
                },
                line_linked: {
                    enable: false,
                },
                move: {
                    enable: true,
                    speed: 1,
                    direction: "none",
                    out_mode: "out",
                },
            },
            interactivity: {
                detect_on: "canvas",
                events: {
                    onhover: {
                        enable: false,
                    },
                    onclick: {
                        enable: false,
                    },
                },
            },
            retina_detect: true,
        });
    </script>
</Layout>
