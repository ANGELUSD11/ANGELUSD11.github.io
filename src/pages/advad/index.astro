---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="ADVAD - ANGELUS11">
    <div class="container-fluid p-0 position-relative" style="z-index: 10;">
        <header
            class="py-4 px-4 border-bottom"
            style="background-color: rgba(2, 22, 36, 0.31); backdrop-filter: blur(8px);">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center">
                    <a href="/" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <div class="d-flex align-items-center gap-3 mx-auto">
                        <i class="fas fa-rocket text-primary fs-4"></i>
                        <h1 class="h3 mb-0 text-primary">ADVAD</h1>
                    </div>
                </div>
            </div>
        </header>

        <section class="py-5 px-4">
            <div class="container">
                <img
                    src="/images/ADVADLOGODEF.png"
                    alt="ADVAD Logo"
                    class="game-logo img-fluid mb-3"/>
                <div class="game-container">
                    <div class="ratio ratio-16x9">
                        <iframe
                            frameborder="0"
                            title="ADVAD demo"
                            src="https://itch.io/embed-upload/16830827?color=00477e"
                            allowfullscreen
                            width="1280"
                            height="720"></iframe>
                    </div>
                </div>

                <div class="card bg-dark-subtle border-primary mt-4">
                    <div class="card-body">
                        <h2 class="card-title text-primary mb-4">
                            <i class="fas fa-gamepad me-2"></i>
                            <span
                                data-es="Sobre el juego"
                                data-en="About the game">Sobre el juego
                            </span>
                        </h2>
                        <p
                            class="card-text text-white"
                            data-es="ADVAD es un 'shoot 'em up' espacial de ritmo rápido. Pilota tu nave, esquiva oleadas de enemigos y asteroides, y destruye todo a tu paso para conseguir la puntuación más alta. ¿Cuánto tiempo podrás sobrevivir?"
                            data-en="ADVAD is a fast-paced space shoot 'em up. Pilot your ship, dodge waves of enemies and asteroids, and destroy everything in your path to get the highest score. How long can you survive?">
                            ADVAD es un 'shoot 'em up' espacial de ritmo rápido.
                            Pilota tu nave, esquiva oleadas de enemigos y
                            asteroides, y destruye todo a tu paso para conseguir
                            la puntuación más alta. ¿Cuánto tiempo podrás
                            sobrevivir?
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- The external itch.io widget at the bottom -->
    <div class="d-flex justify-content-center itch-io-widget-container py-5">
        <iframe
            title="ADVAD itch.io widget"
            frameborder="0"
            src="https://itch.io/embed/3972224?bg_color=234446&fg_color=58fffa&link_color=7bfffd&border_color=276ea5"
            width="552"
            height="167"
            loading="lazy"></iframe>
    </div>

    <div class="container py-5">
        <div class="card bg-dark-subtle border-primary shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-primary mb-4 text-center">
                    <i class="fas fa-trophy me-2"></i>
                    <span
                        data-es="Tabla de clasificación"
                        data-en="Leaderboards">Tabla de clasificación
                    </span>
                </h2>
                <div class="mx-auto" style="max-width: 1140px;">
                    <div class="ratio ratio-16x9" style="min-height: 600px;">
                        <iframe
                            src="https://advad1d.github.io/advad-leaderboard-front/embed/"
                            width="100%"
                            height="100%"
                            style="border:0; border-radius: 8px;"
                            loading="lazy"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Language Switcher Button (floating in advad) -->
    <div class="language-switcher">
        <button id="langBtn" class="btn btn-outline-primary">
            <i class="fas fa-globe"></i>
            <span id="langText">EN</span>
        </button>
    </div>
</Layout>
