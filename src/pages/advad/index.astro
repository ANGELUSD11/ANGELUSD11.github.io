---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="ADVAD - ANGELUS11">
    <div class="container-fluid p-0 position-relative" style="z-index: 10;">
        <header
            class="py-4 px-4 border-bottom"
            style="background-color: rgba(2, 22, 36, 0.31); backdrop-filter: blur(8px);"
        >
            <div class="container">
                <div class="d-flex justify-content-between align-items-center">
                    <a href="/" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <div class="d-flex align-items-center gap-3 mx-auto">
                        <i class="fas fa-rocket text-primary fs-4"></i>
                        <h1 class="h3 mb-0 text-primary">ADVAD</h1>
                    </div>
                </div>
            </div>
        </header>

        <section class="py-5 px-4">
            <div class="container">
                <img
                    src="/images/ADVADLOGODEF.png"
                    alt="ADVAD Logo"
                    class="game-logo img-fluid mb-3"
                />
                <div class="game-stage mx-auto">
                    <iframe
                        id="advadFrame"
                        class="game-frame"
                        frameborder="0"
                        title="ADVAD demo"
                        src="/advad-game/"
                        allow="autoplay; fullscreen; gamepad; clipboard-write"
                        allowfullscreen></iframe>
                </div>

                <div class="card bg-dark-subtle border-primary mt-4">
                    <div class="card-body">
                        <h2 class="card-title text-primary mb-4">
                            <i class="fas fa-gamepad me-2"></i>
                            <span
                                data-es="Sobre el juego"
                                data-en="About the game"
                                >Sobre el juego
                            </span>
                        </h2>
                        <p
                            class="card-text text-white"
                            data-es="ADVAD es un 'shoot 'em up' espacial de ritmo rápido. Pilota tu nave, esquiva oleadas de enemigos y asteroides, y destruye todo a tu paso para conseguir la puntuación más alta. ¿Cuánto tiempo podrás sobrevivir?"
                            data-en="ADVAD is a fast-paced space shoot 'em up. Pilot your ship, dodge waves of enemies and asteroids, and destroy everything in your path to get the highest score. How long can you survive?"
                        >
                            ADVAD es un 'shoot 'em up' espacial de ritmo rápido.
                            Pilota tu nave, esquiva oleadas de enemigos y
                            asteroides, y destruye todo a tu paso para conseguir
                            la puntuación más alta. ¿Cuánto tiempo podrás
                            sobrevivir?
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- The external itch.io widget at the bottom -->
    <div class="d-flex justify-content-center itch-io-widget-container py-5">
        <iframe
            title="ADVAD itch.io widget"
            frameborder="0"
            src="https://itch.io/embed/3972224?bg_color=234446&fg_color=58fffa&link_color=7bfffd&border_color=276ea5"
            width="552"
            height="167"
            loading="lazy"></iframe>
    </div>

    <div class="container py-5">
        <div class="card bg-dark-subtle border-primary shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-primary mb-4 text-center">
                    <i class="fas fa-trophy me-2"></i>
                    <span
                        data-es="Tabla de clasificación"
                        data-en="Leaderboards"
                        >Tabla de clasificación
                    </span>
                </h2>
                <div class="mx-auto" style="max-width: 1140px;">
                    <div class="ratio ratio-16x9" style="min-height: 600px;">
                        <iframe
                            src="https://advad1d.github.io/advad-leaderboard-front/embed/"
                            width="100%"
                            height="100%"
                            style="border:0; border-radius: 8px;"
                            loading="lazy"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Language Switcher Button (floating in advad) -->
    <div class="language-switcher">
        <button id="langBtn" class="btn btn-outline-primary">
            <i class="fas fa-globe"></i>
            <span id="langText">EN</span>
        </button>
    </div>

    <style>
        /* "Escenario" del juego: reserva el espacio visual y recorta el iframe escalado.
           Misma proporción que la resolución nativa del juego (520x300). */
        .game-stage {
            position: relative;
            width: 100%;
            max-width: 1040px; /* ancho visual maximo (el render es 780, se escala ~1.33x) */
            aspect-ratio: 520 / 300;
            margin-inline: auto;
            overflow: hidden;
            background: #000;
            border-radius: 8px;
        }

        /* El iframe renderiza 780x450 px reales (1.5x el nativo 520x300, misma
           proporcion): el shader CRT procesa ~351k px en vez de ~2M, sigue barato
           y los textos del juego se leen mejor. El tamano visual grande lo da el
           transform: scale() de fitAdvad(). */
        .game-frame {
            position: absolute;
            top: 0;
            left: 0;
            width: 780px;
            height: 450px;
            border: 0;
            transform-origin: top left;
            image-rendering: pixelated; /* upscale nitido para el pixel-art */
        }
    </style>

    <script is:inline>
        // Renderiza a 780x450 (barato para el shader) y escala por CSS hasta
        // llenar el ancho real del "escenario". El divisor DEBE ser el mismo
        // numero que el width del .game-frame, o el iframe se desborda.
        function fitAdvad() {
            const stage = document.querySelector(".game-stage");
            const frame = document.getElementById("advadFrame");
            if (!stage || !frame) return;
            const scale = stage.clientWidth / 780;
            frame.style.transform = "scale(" + scale + ")";
        }
        window.addEventListener("resize", fitAdvad);
        window.addEventListener("load", fitAdvad);
        fitAdvad();
    </script>
</Layout>
